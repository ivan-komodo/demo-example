      Инвариант "mark_as_read идемпотентен" соблюдается
    </check>
  </consistency>
  
  <test-scenarios>
    
    <group level="deterministic">
      <scenario id="SC-007-001">
        <name>Успешное создание уведомления</name>
        <description>Система создаёт уведомление для пользователя</description>
        <anchor ref="NOTIFICATION_CREATE"/>
        <given>
          - user_id = existing_user
          - type = 'enrollment'
          - title = 'Запись на курс'
          - message = 'Вы записаны на курс "Основы Python"'
        </given>
        <when>create_notification()</when>
        <then>
          <assertion type="equal">
            <actual>notification.is_read</actual>
            <expected>false</expected>
          </assertion>
          <assertion type="not_null">
            <actual>notification.created_at</actual>
          </assertion>
        </then>
      </scenario>
      
      <scenario id="SC-007-002">
        <name>Ошибка - пользователь не существует</name>
        <description>Нельзя создать уведомление для несуществующего пользователя</description>
        <anchor ref="NOTIFICATION_CREATE"/>
        <given>
          - user_id = non_existent_user
        </given>
        <when>create_notification()</when>
        <then>
          <assertion type="equal">
            <actual>result</actual>
            <expected>error</expected>
          </assertion>
        </then>
      </scenario>
      
      <scenario id="SC-007-003">
        <name>Успешная отметка прочитанным</name>
        <description>Пользователь отмечает уведомление как прочитанное</description>
        <anchor ref="NOTIFICATION_MARK_READ"/>
        <given>
          - notification_id = existing_notification (user's own)
          - notification.is_read = false
        </given>
        <when>PATCH /api/notifications/{id}/</when>
        <then>
          <assertion type="equal">
            <actual>response.status_code</actual>
            <expected>200</expected>
          </assertion>
          <assertion type="equal">
            <actual>notification.is_read</actual>
            <expected>true</expected>
          </assertion>
        </then>
      </scenario>
      
      <scenario id="SC-007-004">
        <name>Идемпотентность mark_as_read</name>
        <description>Повторная отметка не вызывает ошибку</description>
        <anchor ref="NOTIFICATION_MARK_READ"/>
        <given>
          - notification.is_read = true (уже прочитано)
        </given>
        <when>PATCH /api/notifications/{id}/</when>
        <then>
          <assertion type="equal">
            <actual>response.status_code</actual>
            <expected>200</expected>
          </assertion>
          <assertion type="equal">
            <actual>response.data.success</actual>
            <expected>true</expected>
          </assertion>
        </then>
      </scenario>
      
      <scenario id="SC-007-005">
        <name>Ошибка - чужое уведомление</name>
        <description>Нельзя отметить чужое уведомление</description>
        <anchor ref="NOTIFICATION_MARK_READ"/>
        <given>
          - notification принадлежит другому пользователю
        </given>
        <when>PATCH /api/notifications/{id}/</when>
        <then>
          <assertion type="equal">
            <actual>response.status_code</actual>
            <expected>403</expected>
          </assertion>
        </then>
      </scenario>
    </group>
    
    <group level="trajectory">
      <scenario id="SC-007-101">
        <name>Проверка лог-маркеров для NOTIFICATION_CREATE</name>
        <anchor ref="NOTIFICATION_CREATE"/>
        <required-log-markers>
          <marker point="ENTRY">
            <pattern>[notifications][create_notification][NOTIFICATION_CREATE][ENTRY]</pattern>
            <must-contain>
              <field>user_id</field>
              <field>type</field>
            </must-contain>
          </marker>
          <marker point="EXIT">
            <pattern>[notifications][create_notification][NOTIFICATION_CREATE][EXIT]</pattern>
            <must-contain>
              <field>result</field>
              <field>notification_id</field>
            </must-contain>
          </marker>
        </required-log-markers>
      </scenario>
      
      <scenario id="SC-007-102">
        <name>Проверка лог-маркеров для NOTIFICATION_MARK_READ</name>
        <anchor ref="NOTIFICATION_MARK_READ"/>
        <required-log-markers>
          <marker point="ENTRY">
            <pattern>[notifications][mark_as_read][NOTIFICATION_MARK_READ][ENTRY]</pattern>
            <must-contain>
              <field>notification_id</field>
            </must-contain>
          </marker>
          <marker point="EXIT">
            <pattern>[notifications][mark_as_read][NOTIFICATION_MARK_READ][EXIT]</pattern>
            <must-contain>
              <field>result</field>
            </must-contain>
          </marker>
        </required-log-markers>
      </scenario>
    </group>
    
    <group level="integration">
      <scenario id="SC-007-201">
        <name>E2E: Просмотр и отметка уведомлений</name>
        <description>Пользователь просматривает уведомления и отмечает прочитанными</description>
        <steps>
          <step order="1">
            <action>Пользователь открывает страницу уведомлений</action>
            <expected>Отображается список уведомлений</expected>
          </step>
          <step order="2">
            <action>Загружается счётчик непрочитанных</action>
            <expected>Badge с количеством непрочитанных</expected>
          </step>
          <step order="3">
            <action>Пользователь кликает "Прочитано"</action>
            <expected>PATCH /api/notifications/{id}/ возвращает 200</expected>
            <verify-markers>
              <marker ref="SC-007-102"/>
            </verify-markers>
          </step>
          <step order="4">
            <action>Счётчик обновляется</action>
            <expected>Количество уменьшилось на 1</expected>
          </step>
        </steps>
      </scenario>
    </group>
    
  </test-scenarios>
  
  <recommendations/>
  
</validation-report>
