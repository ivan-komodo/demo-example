  <test-scenarios>
    
    <group level="deterministic">
      <scenario id="SC-003-001">
        <name>Успешное создание курса</name>
        <description>Админ создаёт новый курс</description>
        <anchor ref="COURSE_CREATE"/>
        <given>
          - request.user.role == 'admin'
          - title = 'Основы Python' (1-255 символов)
          - description = 'Курс для начинающих' (опционально)
        </given>
        <when>POST /api/courses/</when>
        <then>
          <assertion type="equal">
            <actual>response.status_code</actual>
            <expected>201</expected>
          </assertion>
          <assertion type="equal">
            <actual>response.data.status</actual>
            <expected>draft</expected>
          </assertion>
        </then>
      </scenario>
      
      <scenario id="SC-003-002">
        <name>Успешная публикация курса</name>
        <description>Админ публикует курс с модулями</description>
        <anchor ref="COURSE_PUBLISH"/>
        <given>
          - request.user.role == 'admin'
          - course.status = 'draft'
          - course имеет минимум 1 модуль
        </given>
        <when>POST /api/courses/{id}/publish/</when>
        <then>
          <assertion type="equal">
            <actual>response.status_code</actual>
            <expected>200</expected>
          </assertion>
          <assertion type="equal">
            <actual>response.data.status</actual>
            <expected>published</expected>
          </assertion>
        </then>
      </scenario>
      
      <scenario id="SC-003-003">
        <name>Ошибка публикации пустого курса</name>
        <description>Нельзя опубликовать курс без модулей</description>
        <anchor ref="COURSE_PUBLISH"/>
        <given>
          - course.status = 'draft'
          - course.module_count = 0
        </given>
        <when>POST /api/courses/{id}/publish/</when>
        <then>
          <assertion type="equal">
            <actual>response.status_code</actual>
            <expected>400</expected>
          </assertion>
          <assertion type="equal">
            <actual>response.data.error</actual>
            <expected>COURSE_MUST_HAVE_MODULES</expected>
          </assertion>
        </then>
      </scenario>
      
      <scenario id="SC-003-004">
        <name>Успешное создание модуля</name>
        <description>Админ добавляет модуль к курсу</description>
        <anchor ref="MODULE_CREATE"/>
        <given>
          - request.user.role == 'admin'
          - course_id = existing_course
          - title = 'Введение'
          - content_type = 'text'
          - content_text = 'Содержимое модуля...'
        </given>
        <when>POST /api/modules/</when>
        <then>
          <assertion type="equal">
            <actual>response.status_code</actual>
            <expected>201</expected>
          </assertion>
          <assertion type="equal">
            <actual>response.data.order_num</actual>
            <expected>1</expected>
          </assertion>
        </then>
      </scenario>
      
      <scenario id="SC-003-005">
        <name>Автоматический order_num для модулей</name>
        <description>Второй модуль получает order_num=2</description>
        <anchor ref="MODULE_CREATE"/>
        <given>
          - course уже имеет 1 модуль
          - создаётся второй модуль
        </given>
        <when>POST /api/modules/</when>
        <then>
          <assertion type="equal">
            <actual>response.data.order_num</actual>
            <expected>2</expected>
          </assertion>
        </then>
      </scenario>
      
      <scenario id="SC-003-006">
        <name>Успешная запись на курс</name>
        <description>Админ записывает пользователя на курс</description>
        <anchor ref="COURSE_ENROLL"/>
        <given>
          - request.user.role == 'admin'
          - user_id = active_user
          - course_id = published_course
          - пользователь ещё не записан
        </given>
        <when>POST /api/courses/{id}/enroll/</when>
        <then>
          <assertion type="equal">
            <actual>response.status_code</actual>
            <expected>201</expected>
          </assertion>
          <assertion type="equal">
            <actual>CourseEnrollment.status</actual>
            <expected>active</expected>
          </assertion>
        </then>
      </scenario>
      
      <scenario id="SC-003-007">
        <name>Ошибка записи на неопубликованный курс</name>
        <description>Нельзя записаться на draft курс</description>
        <anchor ref="COURSE_ENROLL"/>
        <given>
          - course.status = 'draft'
        </given>
        <when>POST /api/courses/{id}/enroll/</when>
        <then>
          <assertion type="equal">
            <actual>response.status_code</actual>
            <expected>400</expected>
          </assertion>
          <assertion type="equal">
            <actual>response.data.error</actual>
            <expected>COURSE_NOT_PUBLISHED</expected>
          </assertion>
        </then>
      </scenario>
      
      <scenario id="SC-003-008">
        <name>Изменение порядка модулей</name>
        <description>Админ меняет порядок модулей</description>
        <anchor ref="MODULE_REORDER"/>
        <given>
          - course имеет модули [M1, M2, M3]
          - new_order = [M3, M1, M2]
        </given>
        <when>POST /api/courses/{id}/reorder/</when>
        <then>
          <assertion type="equal">
            <actual>M3.order_num</actual>
            <expected>1</expected>
          </assertion>
          <assertion type="equal">
            <actual>M1.order_num</actual>
            <expected>2</expected>
          </assertion>
          <assertion type="equal">
            <actual>M2.order_num</actual>
            <expected>3</expected>
          </assertion>
        </then>
      </scenario>
      
      <scenario id="SC-003-009">
        <name>Удаление модуля с пересчётом order_num</name>
        <description>При удалении модуля порядок пересчитывается</description>
        <anchor ref="MODULE_DELETE"/>
        <given>
          - course имеет модули [M1(order=1), M2(order=2), M3(order=3)]
          - удаляется M2
        </given>
        <when>DELETE /api/modules/{M2}/</when>
        <then>
          <assertion type="equal">
            <actual>M1.order_num</actual>
            <expected>1</expected>
          </assertion>
          <assertion type="equal">
            <actual>M3.order_num</actual>
            <expected>2</expected>
          </assertion>
        </then>
      </scenario>
    </group>
    
