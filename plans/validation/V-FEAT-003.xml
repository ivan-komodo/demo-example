    <group level="integration">
      <scenario id="SC-003-201">
        <name>E2E: Создание и публикация курса</name>
        <description>Админ создаёт курс, добавляет модули и публикует</description>
        <steps>
          <step order="1">
            <action>Админ входит в систему</action>
            <expected>Успешный логин</expected>
          </step>
          <step order="2">
            <action>Админ создаёт новый курс</action>
            <expected>POST /api/courses/ возвращает 201, status=draft</expected>
            <verify-markers>
              <marker ref="SC-003-101"/>
            </verify-markers>
          </step>
          <step order="3">
            <action>Админ добавляет 3 модуля к курсу</action>
            <expected>Модули создаются с order_num 1, 2, 3</expected>
            <verify-markers>
              <marker ref="SC-003-103"/>
