          <step order="4">
            <action>Админ пытается опубликовать курс</action>
            <expected>POST /api/courses/{id}/publish/ возвращает 200</expected>
            <verify-markers>
              <marker ref="SC-003-102"/>
            </verify-markers>
          </step>
          <step order="5">
            <action>Курс виден в списке опубликованных</name>
            <expected>GET /api/courses/?status=published включает новый курс</expected>
