            </must-contain>
          </marker>
          <marker point="EXIT">
            <pattern>[courses][create_module][MODULE_CREATE][EXIT]</pattern>
            <must-contain>
              <field>result</field>
              <field>module_id</field>
              <field>order_num</field>
            </must-contain>
          </marker>
        </required-log-markers>
      </scenario>
      
      <scenario id="SC-003-104">
        <name>Проверка лог-маркеров для COURSE_ENROLL</name>
        <anchor ref="COURSE_ENROLL"/>
        <required-log-markers>
          <marker point="ENTRY">
            <pattern>[courses][enroll_user][COURSE_ENROLL][ENTRY]</pattern>
            <must-contain>
              <field>user_id</field>
              <field>course_id</field>
            </must-contain>
          </marker>
          <marker point="STATE_CHANGE">
            <pattern>[courses][enroll_user][COURSE_ENROLL][STATE_CHANGE]</pattern>
            <must-contain>
              <field>entity</field>
